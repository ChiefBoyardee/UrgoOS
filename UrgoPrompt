### 17.2 Create clone script

Create `scripts/clone-research-repos.sh`:

```bash
#!/usr/bin/env bash
set -euo pipefail

mkdir -p research/upstream
cd research/upstream

clone_or_update() {
  local repo="$1"
  local dir="$2"

  if [ -d "$dir/.git" ]; then
    echo "Updating $dir"
    git -C "$dir" fetch --all --prune
  else
    echo "Cloning $repo"
    git clone "$repo" "$dir"
  fi

  echo "$dir @ $(git -C "$dir" rev-parse HEAD)"
}

